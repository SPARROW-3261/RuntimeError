# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OpenRouteService API Key (Optional, simulated if missing)
ORS_API_KEY=""

# Routing engine selection: "ors" (default) or "otp" (OpenTripPlanner).
ROUTING_ENGINE="ors"

# OpenTripPlanner (OTP) settings (no Docker required).
# Run OTP locally (java) and point the app here.
OTP_BASE_URL="http://localhost:8080"
# OTP1 default REST plan endpoint:
OTP_PLAN_PATH="/otp/routers/default/plan"

# Air Quality (Optional): WAQI token for AQI exposure scoring.
# If missing, exposure scoring falls back to a simple heuristic.
WAQI_TOKEN=""

# Frontend map mode
# Set true to use MapLibre vector tiles in RouteMap (fallback map remains available).
VITE_USE_VECTOR_TILES="false"

# MapLibre style URL (JSON). Use a style that references your tile source(s).
# Example (demo): https://demotiles.maplibre.org/style.json
VITE_MAP_STYLE_URL="https://demotiles.maplibre.org/style.json"

# Optional PMTiles archive URL. If your style uses pmtiles:// sources, set this.
# Example: https://your-cdn/ranchi.pmtiles
VITE_PMTILES_URL=""
